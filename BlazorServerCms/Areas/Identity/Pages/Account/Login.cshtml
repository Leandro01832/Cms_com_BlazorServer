@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <h2>Use uma conta local para log in.</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-floating">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                    <label asp-for="Input.Email" class="form-label"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                    <label asp-for="Input.Password" class="form-label"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div>
                    <div class="checkbox">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div>
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>Use another service to log in.</h3>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715">article
                            about setting up this ASP.NET application to support logging in via external services</a>.
                        </p>
                    </div>
                    <div class="g-signin2" data-onsuccess="onSignIn"></div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>
                            <p>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                                }
                            </p>
                        </div>
                    </form>
                }
            }
        </section>
    </div>
   
        <div class="form-group mt-3">
            <button type="button" id="btnLoginBiometria" class="btn btn-dark w-100">
                👤 Entrar com Biometria / Passkey
            </button>
        </div>
   

</div>

@section Scripts {
    @* <partial name="_ValidationScriptsPartial" /> *@
    <script>
     
     document.getElementById('btnLoginBiometria').addEventListener('click', async () => {
    try {
        // Captura o input de e-mail padrão do ASP.NET Core Identity
        const emailInput = document.getElementById('Input_Email') || document.querySelector('input[type="email"]');
        
        if (!emailInput || !emailInput.value) {
            alert('Por favor, digite o seu e-mail antes de entrar com a biometria.');
            return;
        }

        // Monta o formulário para enviar ao C#
        const formData = new FormData();
        formData.append('username', emailInput.value);

        // 1. Busca os parâmetros do desafio no servidor
        const responseOpcoes = await fetch('/api/webauthn/login-options', { 
            method: 'POST',
            body: formData // Envia o e-mail aqui
        });
        
        if (!responseOpcoes.ok) throw new Error('Erro ao buscar opções de login.');

        const options = await responseOpcoes.json();

        // Converte o Challenge de Base64 para binário (UInt8Array)
        options.publicKey.challenge = Uint8Array.from(atob(options.publicKey.challenge), c => c.charCodeAt(0));

        // 2. Dispara o leitor biométrico do navegador (ou o painel virtual do Edge)
        const assertion = await navigator.credentials.get({
            publicKey: options.publicKey
        });

        // 3. Empacota a assinatura gerada pelo hardware/emulador
        const dadosParaEnviar = {
            id: assertion.id,
            rawId: btoa(String.fromCharCode.apply(null, new Uint8Array(assertion.rawId))),
            type: assertion.type,
            response: {
                authenticatorData: btoa(String.fromCharCode.apply(null, new Uint8Array(assertion.response.authenticatorData))),
                clientDataJSON: btoa(String.fromCharCode.apply(null, new Uint8Array(assertion.response.clientDataJSON))),
                signature: btoa(String.fromCharCode.apply(null, new Uint8Array(assertion.response.signature))),
                userHandle: assertion.response.userHandle ? btoa(String.fromCharCode.apply(null, new Uint8Array(assertion.response.userHandle))) : null
            }
        };

        // 4. Envia para o C# conferir a assinatura digital no método de verificação
        const resultadoFinal = await fetch('/api/webauthn/login-verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dadosParaEnviar)
        });

        const respostaServidor = await resultadoFinal.json();

        if (respostaServidor.success) {
            alert('Autenticado com sucesso! Redirecionando...');
            window.location.href = '/'; // Redireciona para a home logado
        } else {
            alert('Chave biométrica inválida ou não cadastrada.');
        }

    } catch (error) {
        console.error(error);
        alert('Falha no login: ' + error.message);
    }
});
    
    
    
    </script>
}
