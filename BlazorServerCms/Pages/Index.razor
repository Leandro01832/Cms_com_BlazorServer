    private int retornarVersoComCriterio(SubFiltro c)
    {
        var f = Context!.SubFiltro
        .Include(s => s.Criterio)
        .ThenInclude(s => s.Content)
        .FirstOrDefault(f => f.FiltroId == c.Id);
        if (f == null)
        {
            if(c.Criterio != null)
            {
                f = Context.SubFiltro
                .Include(s => s.Criterio)
                .ThenInclude(s => s.Content)
                .FirstOrDefault(s => s.FiltroId == c.Id);

                return retornarVerso(f.Criterio.Content!);

            }
            try
            {

                if(c == null)
                    return 0;
                else if(c.Criterio == null)
                {
                    f = Context.SubFiltro
                .Include(s => s.Criterio)
                .ThenInclude(s => s.Content)
                .FirstOrDefault(s => s.Id == c.ComCriterio);
                    return retornarVerso(f.Criterio.Content!);

                }
            }
            catch(Exception ex)
            {
                return 0;
            }

            return 0; 

        } 
        else
        {
            if(c.Criterio == null){
                f = Context.SubFiltro
                    .Include(s => s.Criterio)
                    .ThenInclude(s => s.Content)
                    .FirstOrDefault(s => s.Id == c.ComCriterio); 
            }
            var retorno = retornarVerso(f.Criterio.Content!);
            return retorno;
        }
    }

