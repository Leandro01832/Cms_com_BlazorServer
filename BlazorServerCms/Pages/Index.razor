    private List<SubFiltro> PesquisarComMaisCriterio(List<string> termos)
    {
        //tratando sql injection e otimizando a consulta para evitar múltiplas id's
        List<SubFiltro> result = new List<SubFiltro>();
            

        if (termos == null || termos.Count == 0)
            return result;

        try
        {
            using (var con = new SqlConnection(ApplicationDbContext._connectionString))
            {
                StringBuilder sql = new StringBuilder();
                sql.Append("WITH ArvoreRecursiva AS ( "); // OVER() é mais eficiente para totalizadores
                sql.Append("SELECT g.Id, g.FiltroId, g.CriterioId, g.Nome FROM Filtro g "); // OVER() é mais eficiente para totalizadores
                sql.Append("INNER JOIN HashtagFiltro gh ON g.Id = gh.FiltroId "); // OVER() é mais eficiente para totalizadores
                sql.Append("INNER JOIN Hashtag ha ON gh.HashtagId = ha.Id "); // OVER() é mais eficiente para totalizadores
                sql.Append("WHERE  "); // OVER() é mais eficiente para totalizadores
                

                var cmd = new SqlCommand();
                List<string> condicoes = new List<string>();

                // Criando parâmetros dinamicamente para cada palavra da busca
                for (int i = 0; i < termos.Count; i++)
                    condicoes.Add($" ha.Name LIKE '%{termos[i]}%' OR g.Nome LIKE '%{termos[i]}%' "); // OVER() é mais eficiente para totalizadores


                sql.Append(string.Join(" OR ", condicoes));
                sql.Append(" UNION ALL SELECT t.Id, t.FiltroId, t.CriterioId, t.Nome FROM Filtro t INNER JOIN ArvoreRecursiva r ON t.FiltroId = r.Id ");
                sql.Append(" ) SELECT DISTINCT Id, FiltroId, CriterioId, Nome FROM ArvoreRecursiva; "); 

                cmd.CommandText = sql.ToString(); 
                cmd.Connection = con;

                con.Open();
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        result.Add(new SubFiltro
                    {
                        Id = reader.IsDBNull(0) ? 0 : reader.GetInt64(0),
                        FiltroId = reader.IsDBNull(1) ? 0 : reader.GetInt64(1),
                        CriterioId = reader.IsDBNull(2) ? 0 : reader.GetInt64(2),
                        Nome = reader.IsDBNull(3) ? string.Empty : reader.GetString(3) 
                    });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao pesquisar com mais critério: {ex.Message}");
            return new List<SubFiltro>();
        }
        return result;
    }

    private void PesquisarComMaisCriterio2(List<string> termos)
    {
        filtros.Clear();
        var lista = PesquisarComMaisCriterio(termos);
        if(lista.Count > 0)
        foreach(var item in lista)
        {
            var f = Context.SubFiltro
            .Include(s => s.Criterio)
            .ThenInclude(s => s.Content)
            .FirstOrDefault(f => f.Id == item.Id && !f.UltimaPasta);
            if(f != null)
                filtros.Add(f); 
        }
       
    }
   
   public List<string> maisCriterio(string query, List<SubFiltro>? filtros2)
{
    if (string.IsNullOrWhiteSpace(query)) return new List<string>();    

    var termosEncontrados = new List<string>();
    
    // 2. Dividimos a query por espaços e removemos entradas vazias
    var palavrasUsuario = query.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

    // 3. Verificamos cada palavra (ou combinações)
    foreach (var palavra in palavrasUsuario)
    {
        if (!stopWords.Contains(palavra) && termosValidos.Contains(palavra))
        {
            termosEncontrados.Add(palavra.ToLower());
        }
    }

    return termosEncontrados.Distinct().ToList();
}
