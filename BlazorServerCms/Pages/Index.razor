    private List<SubFiltro> PesquisarComMaisCriterio(List<string> termos)
    {
        //tratando sql injection e otimizando a consulta para evitar múltiplas id's
        List<SubFiltro> result = new List<SubFiltro>();

        if (termos == null || termos.Count == 0)
            return result;

        try
        {
            using (var con = new SqlConnection(ApplicationDbContext._connectionString))
            {
                StringBuilder sql = new StringBuilder();
                sql.Append("WITH ArvoreRecursiva AS ( "); // OVER() é mais eficiente para totalizadores
                sql.Append("SELECT Id, FiltroId, CriterioId, Nome "); // OVER() é mais eficiente para totalizadores
                sql.Append("FROM Filtro WHERE ");

                var cmd = new SqlCommand();
                List<string> condicoes = new List<string>();

                // Criando parâmetros dinamicamente para cada palavra da busca
                for (int i = 0; i < termos.Count; i++)
                    condicoes.Add($"Nome LIKE '{termos[i]}'");


                sql.Append(string.Join(" OR ", condicoes));
                sql.Append(" UNION ALL SELECT t.Id, t.FiltroId, t.CriterioId, t.Nome FROM Filtro t INNER JOIN ArvoreRecursiva r ON t.FiltroId = r.Id ");
                sql.Append(" ) SELECT * FROM ArvoreRecursiva; "); 

                cmd.CommandText = sql.ToString(); 
                cmd.Connection = con;

                con.Open();
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        result.Add(new SubFiltro
                    {
                        Id = reader.IsDBNull(0) ? 0 : reader.GetInt64(0),
                        FiltroId = reader.IsDBNull(1) ? 0 : reader.GetInt64(1),
                        CriterioId = reader.IsDBNull(2) ? 0 : reader.GetInt64(2),
                        Nome = reader.IsDBNull(3) ? string.Empty : reader.GetString(3) 
                    });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao pesquisar com mais critério: {ex.Message}");
            return new List<SubFiltro>();
        }
        return result;
    }

    private void PesquisarComMaisCriterio2(List<string> termos)
    {
        filtros.Clear();
        var lista = PesquisarComMaisCriterio(termos);
        foreach(var item in lista)
        {
            var f = Context.SubFiltro
            .Include(s => s.Criterio)
            .ThenInclude(s => s.Content)
            .FirstOrDefault(f => f.Id == item.Id && !f.UltimaPasta);
            if(f != null)
                filtros.Add(f); 
        }
       
    }

    private List<string> maisCriterio()
    {  
        var arr = Query.Trim().Split(' ');
        List<string> termos = new List<string>();
        string teste = Query.ToLower();
        int teste2 = 0;
        if(arr.Length > 1)
            while(teste.Contains(" "))
            {
                foreach(var item in filtros2)
                    if(filtros2
                    .FirstOrDefault(f => teste.Contains(item.Nome.ToLower())) != null)                
                    {
                        termos.Add(item.Nome.ToLower());
                        teste = teste.Replace(item.Nome.ToLower(),"").Trim();                                   
                    }
                    else
                        teste2++;

                if(teste2 > 100)
                    break;
            }

        return termos;
    }

    private async void compartilhar()
    {
        var authState = await AuthenticationStateProvider
        .GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity!.IsAuthenticated)
        {
            var result = "";
            foreach(var item in filtros)            
                result += retornarVerso(item.Criterio.Content!).ToString() + ", ";

            var usuario = await userManager.GetUserAsync(user);
            usuario.Compartilhar = $"({Query} - {string.Join(",", result)})";
            await userManager.UpdateAsync(usuario);             
            await js.InvokeVoidAsync("alert", "Compartilhado com sucesso!");

        }
    }

    private async void anotar()
    {
        //aqui você pode implementar a lógica para anotar o conteúdo
        Console.WriteLine("Anotar conteúdo");
        var authState = await AuthenticationStateProvider
       .GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity!.IsAuthenticated)
        {
            var anotacao = new Anotacao
            {
                UserModelId = userManager.GetUserId(user),
                Query = Query,
                Capitulo = filtros.FirstOrDefault()?.Story?.Capitulo ?? 0,
                LivroId = filtros.FirstOrDefault()?.LivroId,
                DataCriacao = DateTime.Now           
            };
            await Context.Anotacao.AddAsync(anotacao);
            await Context.SaveChangesAsync();

            foreach(var item in filtros)
                anotacao.FazerAnotacao(item);

            await Context.SaveChangesAsync();
            await js.InvokeVoidAsync("alert", "Anotação criada com sucesso!");
        }
    }
