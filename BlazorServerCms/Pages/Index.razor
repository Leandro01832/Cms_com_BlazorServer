    private async void buscar(string textoDigitado)
    {
        Query = textoDigitado;
        //vamos la, aqui é onde a mágica acontece. Quando o usuário digita algo na barra de pesquisa, essa função é chamada. Ela verifica se a consulta (Query) não está vazia e, em seguida, realiza uma busca no banco de dados para encontrar os filtros que correspondem à consulta.

        if (!string.IsNullOrEmpty(Query))
        {
            var termos = maisCriterio();
            if(termos.Count > 1)
            {
                maisDeUmCriterio = true;
                PesquisarComMaisCriterio2(termos);
            }
            else if(termos.Count == 1)
            {
                maisDeUmCriterio = false;
                filtros = filtros2
                .Where(f => f.Nome!.ToLower().Contains(termos[0].ToLower()))
                .ToList();          
            }
            else
            {
                maisDeUmCriterio = false;
                filtros = filtros2
                .Where(f => f.Nome!.ToLower().Contains(Query.ToLower()))
                .ToList();    

            }

        }
        else if (string.IsNullOrEmpty(Query))
        {
            filtros = new List<SubFiltro>();
        }            
    }

