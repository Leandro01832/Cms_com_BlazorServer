@code
{

    [Parameter] public string user { get; set; }
    [Parameter] public int? capitulo { get; set; }
    private DemoContextFactory db = new DemoContextFactory();
    private ApplicationDbContext Context;
    List<Story> stories = new List<Story>();
    List<Relogio> relogios = new List<Relogio>();
    List<SubFiltro>? filtros = new List<SubFiltro>();
    List<UserModel>? seguidores = new List<UserModel>();
    List<UserModel>? seguindo = new List<UserModel>();

    private ClaimsPrincipal usuario;
    private UserModel usermodel;
    private MarkupString markup;
    private int lacos = 0;
    private int itens = 6;
    private int publicacoes = 0;
    private bool newStory = true;
    private bool showModal = false;
    private bool showModal2 = false;
    private bool showModal3 = false;
    private bool isCurrentPlayerProfile = false;
    private bool isFollowing = false;
    private bool reels = false;
    private bool salvo = false;
    private bool publicacao = false;
    private string title = "";
    private string confirmar = "";
    private string classCircle = "";
    private string Html = "";
    private string descricao = "";

    private int cap = 0;
    private int interacao = 0;
    private int somenteUmSemCriterio = 0;

    private string pensamento = "";
    public string Pensamento 
    {
        get{return pensamento;}
        set{
            pensamento = value;
            markup = new MarkupString(usermodel.Compartilhar + value);
        }
    }
    private string Pensar = "";

    private bool semCriterio = false;

    List<Story>[] array;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
           publicacoes = await buscarPublicacoes(0);
            repositoryPagina!.QuantDiv = await repositoryPagina.marcarIndice(false, js);
            repositoryPagina!.QuantDivCriterio = await repositoryPagina.marcarIndice(true, js);

            try
            {
                string? num = await js.InvokeAsync<string>("retornarlargura", "url");
                var largura = double.Parse(num);

                if (largura > 200 && largura < 300)
                    itens = 2;
                else if (largura > 300 && largura < 400)
                    itens = 3;
                else if (largura > 400 && largura < 500)
                    itens = 4;
                else itens = 6;

                lacos = stories.Count / itens;
                var resto = stories.Count % itens;
                if (resto != 0) lacos++;
                array = new List<Story>[lacos];
                var lista = stories.Skip(1).ToList();

                for (var i = 0; i < array.Length; i++)
                {
                    array[i] = new List<Story>();
                    array[i].AddRange(lista.Skip(itens * i).Take(itens).ToList());
                }

            }
            catch (Exception ex)
            {

            }
        }

    }



    protected override void OnParametersSet()
    {
        if (capitulo != null)
            descricao = RepositoryPagina.stories.First(str => str.Capitulo == capitulo).Descricao!;
            
    }

    protected override async Task OnInitializedAsync()
    {
        if (newStory) classCircle = "circuloNewStory";
        else classCircle = "circulo3";

        repositoryPagina.exibir = false;
        Context = db.CreateDbContext(null);
        if (stories.Count == 0)
        {
            stories = RepositoryPagina.stories;
            lacos = stories.Count / itens;
            var resto = stories.Count % itens;
            if (resto != 0) lacos++;
            array = new List<Story>[lacos];
            var lista = stories.Skip(1).ToList();

            for (var i = 0; i < array.Length; i++)
            {
                array[i] = new List<Story>();
                array[i].AddRange(lista.Skip(itens * i).Take(itens).ToList());
            }

        }


        filtros = await Context.SubFiltro!
            .Include(f => f.Camada)!
            .Include(f => f.Criterio)!
            .ThenInclude(f => f.Content)
            .Include(f => f.Pagina)!
            .ThenInclude(f => f.Content)
            .Include(f => f.Story)
            .Include(f => f.Livro)
            .Where(f =>             
             !f.UltimaPasta &&
              f.CriterioId != null && f.Pagina.Count > 0)
              .OrderBy(f => f.Story.Capitulo)
            .ToListAsync();

        usermodel = await Context.Users!
        .Include(u => u.Relogio)!
        .ThenInclude(u => u.Content)!
         .Include(u => u.Relogio)!
        .ThenInclude(u => u.SubFiltro)!
        .ThenInclude(u => u.Story)!
        .Include(u => u.Livro)!
        .ThenInclude(u => u.Livro)!
        .ThenInclude(u => u.Filtro)!
        .FirstOrDefaultAsync(u => u.UserName == user);

        seguidores = await Context.Users
       .Include(u => u.Followers)
    .Where(u => u.Id == usermodel.Id) 
    .SelectMany(u => u.Followers.Select(f => f.Observer)) // Pega o 'Observer' (quem seguiu)
    .ToListAsync();

        seguindo = await Context.Users
            .Include(u => u.Following)
        .Where(u => u.Id == usermodel.Id)
        .SelectMany(u => u.Following.Select(f => f.Target)) // Pega o 'Target' (quem foi seguido)
        .ToListAsync();

        relogios = usermodel.Relogio
        .OrderByDescending(r => r.Data)
        .Take(usermodel.Decorar)
        .ToList();
        relogios = relogios.OrderBy(r => r.SubFiltro.Story!.Capitulo).ToList();

        Pensamento = "(" +
         string.Join(", ", relogios.Select(r => retornarVersoComCriterio(r.SubFiltro))) +
          ")"; 

        if (string.IsNullOrEmpty(usermodel.Compartilhar))
        {
            confirmar = "Compartilhar";
            Pensar = "teste";
            title = "Nova nota";
        }
        else
        {
            confirmar = "Excluir";
            Pensar = "pensar";
            title = "Excluir pensamento";

        }


        var authState = await AuthenticationStateProvider
             .GetAuthenticationStateAsync();
        usuario = authState.User;

        isCurrentPlayerProfile = usuario != null && usuario.Identity!.IsAuthenticated
        && usuario.Identity!.Name == usermodel.UserName;

        var u = await userManager.GetUserAsync(usuario);

        if (!isCurrentPlayerProfile && usuario != null 
        && usuario.Identity!.IsAuthenticated)
            isFollowing = await IsFollowingAsync(u.Id, usermodel.Id);

        

    }  

    private async Task<int> buscarPublicacoes(int condicao)
        {
            try
            {
                string sql = @"SELECT count(*) 
                    FROM Content 
                    WHERE UserModelId = @UserId";
                    
                if(usermodel == null)
                {
                    var cont = db.CreateDbContext(null);
                    var us  = await cont.Users!
                    .FirstOrDefaultAsync(u => u.UserName == user);
                    var con = new SqlConnection(ApplicationDbContext._connectionString);
                    using (SqlCommand cmd = new SqlCommand(sql, con))
                    {
                        cmd.Parameters.AddWithValue("@UserId", us.Id);

                        con.Open();
                        if(publicacoes == 0)
                        publicacoes = int.Parse(cmd.ExecuteScalar().ToString());
                        con.Close();
                    }
                    

                }
                else
                {
                    
                    var con = new SqlConnection(ApplicationDbContext._connectionString);
                    using (SqlCommand cmd = new SqlCommand(sql, con))
                    {
                        cmd.Parameters.AddWithValue("@UserId", usermodel.Id);
                        con.Open();
                        if(publicacoes == 0)
                        publicacoes = int.Parse(cmd.ExecuteScalar().ToString());
                        con.Close();                        
                    }  

                }
            }
            catch (Exception ex)
            {
                publicacoes = 0;
            }
            
                return publicacoes;
        }

    private void limpar()
    {
        descricao = "";
    }

    private async void compartilhar()
    {
        //  string? value = await js.InvokeAsync<string>("retornarTextArea", "contentextarea");
        string value = Html;
        if (!string.IsNullOrEmpty(value))
        {
            usermodel.Compartilhar = value;
            Context.Update(usermodel);
            await Context.SaveChangesAsync();

            Pensamento = value;
            confirmar = "Excluir";
            Pensar = "pensar";
            title = "Excluir pensamento";
            await js!.InvokeAsync<object>("DarAlert", "Compartilhamento feito com sucesso!!!");
        }
    }

    private async void remover()
    {
        if (!string.IsNullOrEmpty(usermodel.Compartilhar))
        {
            usermodel.Compartilhar = null;
            Context.Update(usermodel);
            Context.SaveChanges();
            confirmar = "Compartilhar";
            Pensar = "teste";
            title = "Nova nota";
            await js!.InvokeAsync<object>("DarAlert", "Compartilhamento removido com sucesso!!!");
        }
    }

    private async void navegar(UserModelLivro livro, Story str)
    {
        string? url = null;
        int versiculo = 1;
        SubFiltro? fil = null;
        Relogio rel = null;
        Content contentRel = null;
            int itemConteudo = 0;

        if(livro == null && str.Capitulo == 1)
        {
            livro = new UserModelLivro
                {
                    Livro = await Context.Livro!.FirstAsync(),
                    UserModel = usermodel
                };
        }


        if (livro != null)
        {
            string prompted = await js.InvokeAsync<string>("prompt",
                 "Informe os versiculos para marcar.");
            var filtros = await Context.SubFiltro!
             .OrderBy(f => f.Id)
             .Include(f => f.Criterio)!
             .Include(f => f.Pagina)!
             .ThenInclude(f => f.Content)
             .Where(f => f.LivroId == livro.Livro.Id)
             .ToListAsync();

            if (prompted.Contains(","))
            {
                var arr = prompted.Replace(" ", "").Split(",");
                bool test = true;
                int[] numeros = new int[arr.Length];

                for (var i = 0; i < arr.Length; i++)
                {
                    try
                    {
                        numeros[i] = int.Parse(arr[i]);
                    }
                    catch (Exception)
                    {
                        await js!.InvokeAsync<object>("DarAlert", "Informe apenas numeros separando por virgula");
                        test = false;
                        break;
                    }
                }

                if(test)
                {
                    foreach (var item in numeros)
                    {                        
                        if (Pensamento.Contains(item.ToString()))
                        {
                            var cri = Context.Criterio!
                            .Include(c => c.Filtro)
                            .Include(c => c.Content)
                            .FirstOrDefault(c => c.Content is Chave &&
                             ((Chave)c.Content).Versiculo == item);
                            var fi = ((SubFiltro)cri.Filtro.FirstOrDefault()).FiltroId;
                            rel = usermodel.Relogio.FirstOrDefault(r => r.SubFiltroId == fi);
                            if(rel != null)
                            {
                                contentRel = rel.Content;
                                fil = filtros.FirstOrDefault(f => f.Id == fi);
                                var l = fil.Pagina
                                .Select(p => p.Content)
                                .Where(p => p.GetType() == contentRel.GetType())
                                .OrderBy(p => p.Id)
                                .ToList();
                                var teste = l.FirstOrDefault(c => c.Id == contentRel.Id);
                                itemConteudo = l.IndexOf(teste) + 1;
                            }
                        }                       

                        if(fil != null && contentRel != null)                        
                            url = $"/renderizar/{contentRel!.GetType().Name.ToLower()}/{livro.Livro.Nome}/{str.Capitulo}/{item}/{itemConteudo}/{user}";
                            
                        
                        if(url != null)
                            await js!.InvokeAsync<object>("AcessarSites", $"{url}");
                        url = null;
                    }

                }
            }
            else
            {
                
                if (!string.IsNullOrEmpty(prompted))
                {
                    prompted = prompted.Replace(" ", "");
                    try
                    {
                        semCriterio = prompted.Contains("/s");
                        if(semCriterio)
                        {
                            rel = relogios.OrderBy(r => r.Data)
                            .FirstOrDefault(r => r.SubFiltro.CriterioId == null)!;
                            if(rel != null)
                            {
                                contentRel = rel.Content;                   
                                fil = filtros.FirstOrDefault(f => f.Id == rel.SubFiltroId);
                                var fil2 = filtros.FirstOrDefault(f => f.Id == fil.ComCriterio);
                                var fil3 = filtros.FirstOrDefault(f => f.FiltroId == fil2.Id);
                                versiculo = retornarVerso(fil3.Criterio.Content);
                                var teste = fil.Pagina
                                .OrderBy(p => p.ContentId)
                                .First(p => p.ContentId == contentRel.Id);
                                itemConteudo = fil.Pagina
                                .Where(p => p.Content.GetType() == contentRel.GetType())
                                .OrderBy(p => p.ContentId).ToList().IndexOf(teste) + 1;  
                            }
                        }
                        else
                        versiculo = int.Parse(prompted);
                    }
                    catch (Exception ex)
                    {
                        versiculo = 1;
                    }
                }

                if (Pensamento != null && rel == null)
                {
                    var cri = Context.Criterio!
                    .Include(c => c.Filtro)
                    .Include(c => c.Content)
                    .FirstOrDefault(c => c.Content is Chave && ((Chave)c.Content).Versiculo == versiculo);
                    var fi = ((SubFiltro)cri.Filtro.FirstOrDefault()).FiltroId;
                    rel = usermodel.Relogio.FirstOrDefault(r => r.SubFiltroId == fi);
                    if(rel != null)
                    {
                        contentRel = rel.Content;                   
                        fil = filtros.FirstOrDefault(f => f.Id == fi);
                        var teste = fil.Pagina
                        .OrderBy(p => p.ContentId)
                        .First(p => p.ContentId == contentRel.Id);
                        itemConteudo = fil.Pagina
                        .Where(p => p.Content.GetType() == contentRel.GetType())
                        .OrderBy(p => p.ContentId).ToList().IndexOf(teste) + 1;  
                    }
                }
                
                if( contentRel != null)
                {
                    if(!semCriterio)
                    url = $"/renderizar/{contentRel!.GetType().Name.ToLower()}/{livro.Livro.Nome}/{str.Capitulo}/{versiculo}/{itemConteudo}/{user}";    
                    else               
                    url = $"/renderizar/{contentRel!.GetType().Name.ToLower() + rel.SubFiltroId}/{livro.Livro.Nome}/{str.Capitulo}/{versiculo}/0/{user}";    
                }
                else
                {
                    try
                    {
                        js.InvokeAsync<object>("DarAlert", "Informe o versiculo correto.");
                        url = null;
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine(ex.Message);
                    }
                }                   
                
                if(url != null)
                    await js!.InvokeAsync<object>("AcessarSites", $"{url}");
            }
        }
        else
        {
            url = $"/{user}/{str.Capitulo}";
            navigation.NavigateTo(url);
        }            
    }

