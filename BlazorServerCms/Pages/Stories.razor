     private int retornarPosicaoVerso(Filtro filtro, int versiculo)
    {
        var fil = Context.Filtro!
            .Include(f => f.Pagina)!
            .ThenInclude(p => p.Content)
            .FirstOrDefault(f => f.Id == filtro.Id);
         
        FiltroContent? pagina = fil!.Pagina!.FirstOrDefault(p => p.Content is Pagina && ((Pagina)p.Content!).Versiculo == versiculo);
        if (pagina != null)
        {
            return filtro.Pagina!.IndexOf(pagina) + 1;
        }
        return 0;
    } 

    /// <summary>
    /// Alterna o estado de seguir/deixar de seguir entre dois usuários.
    /// Retorna 'true' se passou a seguir, e 'false' se deixou de seguir.
    /// </summary>
    public async Task<bool> ToggleFollowAsync(string observerId, string targetId)
    {
        // Impedir que o usuário siga a si mesmo
        if (observerId == targetId)
            return false;

        // Procura se o vínculo já existe no banco de dados
        var existingFollow = await Context.Set<UserFollow>()
            .FirstOrDefaultAsync(f => f.ObserverId == observerId && f.TargetId == targetId);

        if (existingFollow != null)
        {
            // Se já segue, remove o registro (Deixar de Seguir)
            Context.Set<UserFollow>().Remove(existingFollow);
            await Context.SaveChangesAsync();
            return false; 
        }
        else
        {
            // Se não segue, cria um novo registro (Seguir)
            var newFollow = new UserFollow
            {
                ObserverId = observerId,
                TargetId = targetId,
                FollowedAt = DateTime.UtcNow
            };

            await Context.Set<UserFollow>().AddAsync(newFollow);
            await Context.SaveChangesAsync();
            return true; 
        }
    }

    /// <summary>
    /// Verifica se o usuário logado já segue o perfil alvo para definir o texto do botão na tela.
    /// </summary>
    public async Task<bool> IsFollowingAsync(string observerId, string targetId)
    {
        return await Context.Set<UserFollow>()
            .AnyAsync(f => f.ObserverId == observerId && f.TargetId == targetId);
    }

    private async Task HandleFollowToggle()
    {
        var authState = await AuthenticationStateProvider
             .GetAuthenticationStateAsync();
        usuario = authState.User;
        var u = await userManager.GetUserAsync(usuario);

        if (u == null || string.IsNullOrEmpty(u.Id)) return;

        // Executa a ação e atualiza o estado visual do botão instantaneamente
        isFollowing = await ToggleFollowAsync(u.Id, usermodel.Id);
    }

