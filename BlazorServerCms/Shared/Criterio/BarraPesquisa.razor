@inject NavigationManager navigation

@inject OllamaApiClient _ollamaService

<div class="filter-group">
  
    <input type="text" class="form-control"  
           placeholder="Pesquisar ou marcar..." 
        @bind="Value" 
       @bind:event="oninput"
           @onkeyup="OnInputChanged" />
           
</div>



@code {
    
    [Parameter] public string Value { get; set; }

    private string UltimoTermoEnviado { get; set; } = "";

     private List<SubFiltro> ResultadosDaBusca = new();

    [Parameter] public EventCallback<string> OnSearch { get; set; }

    private DemoContextFactory db = new DemoContextFactory();

    private ApplicationDbContext Context;

    List<SubFiltro>? filtros2 = new List<SubFiltro>();

    HashSet<string> termosValidos = null;

    HashSet<string> stopWords = null;

    protected override async  Task  OnInitializedAsync()
    {
        Context = db.CreateDbContext(null);
        filtros2 = await Context.SubFiltro!
            .Include(f => f.Camada)!
            .Include(f => f.Criterio)!
            .ThenInclude(f => f.Content)
            .Include(f => f.Pagina)!
            .ThenInclude(f => f.Content)
            .Include(f => f.Story)
            .Include(f => f.Livro)
            .Where(f => 
            //f.Pagina.Count > 0 &&
             !f.UltimaPasta &&
              f.CriterioId != null)
            .ToListAsync();

        termosValidos = new HashSet<string>(
        filtros2.Select(f => f.Nome.Trim()), 
        StringComparer.OrdinalIgnoreCase );

         stopWords = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
        { 
            "de", "do", "da", "dos", "das", "em", "no", "na", "nos", "nas", 
            "com", "por", "para", "um", "uma", "os", "as", "o", "a", "e" 
        };  
    }
    
    private async void OnInputChanged(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // 1. Limpeza: Remove espaços extras (ex: "Baleia     " vira "Baleia")
            var termoLimpo = Value.Trim();

            // 2. Bloqueio: Só envia se o termo atual for diferente do último enviado
            // E se não estiver vazio
            if (!string.IsNullOrWhiteSpace(termoLimpo) && termoLimpo != UltimoTermoEnviado)
            {
                UltimoTermoEnviado = termoLimpo;

                var apenasNumeros = Regex.IsMatch(termoLimpo
                .Replace(" ", "")
                .Replace(",", ""),
                 @"^\d+$");

                if(apenasNumeros)                
                    await OnSearch.InvokeAsync(termoLimpo);                
                else
                {

                    var lista = await PesquisarSemantica(termoLimpo);
                    bool teste = false;
                    
                        for(var i = 0; i < lista.Count; i++)
                        {
                            if(i < 10)
                            {
                                teste = true;
                                await OnSearch.InvokeAsync(lista[i].Nome);
                                break;
                            }
                        }

                   
                    if(!teste)
                    await OnSearch.InvokeAsync(null);

                }

            }
        }
    }
    
      public List<string> maisCriterio(string query, List<SubFiltro>? filtros2)
{
    if (string.IsNullOrWhiteSpace(query)) return new List<string>();    

    var termosEncontrados = new List<string>();
    
    // 2. Dividimos a query por espaços e removemos entradas vazias
    var palavrasUsuario = query.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

    // 3. Verificamos cada palavra (ou combinações)
    foreach (var palavra in palavrasUsuario)
    {
        if (!stopWords.Contains(palavra) && termosValidos.Contains(palavra))
        {
            termosEncontrados.Add(palavra.ToLower());
        }
    }

    return termosEncontrados.Distinct().ToList();
}


   

private async Task<List<SubFiltro>> PesquisarSemantica(string termoBusca)
{
    if (string.IsNullOrWhiteSpace(termoBusca)) return new List<SubFiltro>();

    // 1. Transforma o que o usuário digitou em um vetor (Embedding)
    var request = new EmbedRequest
{
    Model = "mxbai-embed-large",
    // Use um formato de "etiqueta" que ajude a IA a focar no tema
    Input = new List<string> { $"Taxonomia biológica animal: {termoBusca}" }
};
    
    var response = await _ollamaService.EmbedAsync(request);
    float[] vetorUsuario = response.Embeddings[0].Select(d => (float)d).ToArray();

    // 2. Busca todos os filtros do banco que já possuem inteligência (vetor)
    var todosFiltros = await Context.SubFiltro
                               .Where(f => f.VetorEmbedding != null)
                               .ToListAsync();

    // 3. Calcula a similaridade e ordena
    ResultadosDaBusca = todosFiltros
        .Select(f => new { 
            Filtro = f, 
            Score = CalcularSimilaridadeCosseno(vetorUsuario, ConverterByteParaFloat(f.VetorEmbedding)) 
        })
        .OrderByDescending(x => x.Score) // Os mais parecidos primeiro
        .Where(x => x.Score > 0.5)      // Filtro de corte (opcional) para evitar resultados irrelevantes
        .Select(x => x.Filtro) 
        .ToList();

        return ResultadosDaBusca;
}

private float CalcularSimilaridadeCosseno(float[] vetorA, float[] vetorB)
{
    float dotProduct = 0;
    float magnitudeA = 0;
    float magnitudeB = 0;

    for (int i = 0; i < vetorA.Length; i++)
    {
        dotProduct += vetorA[i] * vetorB[i];
        magnitudeA += vetorA[i] * vetorA[i];
        magnitudeB += vetorB[i] * vetorB[i];
    }

    return dotProduct / (MathF.Sqrt(magnitudeA) * MathF.Sqrt(magnitudeB));
}


/// <summary>
/// Converte o array de bytes (varbinary) vindo do SQL Server 
/// de volta para um array de floats para cálculos matemáticos.
/// </summary>
private float[] ConverterByteParaFloat(byte[] bytes)
{
    // 1. Validamos se os bytes existem
    if (bytes == null || bytes.Length == 0) 
        return Array.Empty<float>();

    // 2. Criamos o array de destino com o tamanho exato.
    // Como cada float ocupa 4 bytes, dividimos o tamanho total por 4.
    float[] floats = new float[bytes.Length / sizeof(float)];

    // 3. A "Mágica" da performance: 
    // Copia os dados bit a bit da memória, sem precisar de loops lentos ou JSON.
    Buffer.BlockCopy(bytes, 0, floats, 0, bytes.Length);

    return floats;
}


}