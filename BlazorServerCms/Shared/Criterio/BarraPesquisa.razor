@inject NavigationManager navigation

@inject IJSRuntime js


@using Mscc.GenerativeAI;
@using Mscc.GenerativeAI.Types;

<div class="filter-group">
  
    <input type="text" class="form-control" 
       placeholder="Pesquisar ou marcar..."
       @bind="Value"
       @bind:event="oninput"
       @bind:after="() => OnInputChanged(new ChangeEventArgs { Value = Value })"
       @onkeyup="OnInputChanged" />

        @if(exibir)
        {
           <img src="/Loading.gif" width="50" alt="carregando" />

        }


           
</div>



@code {

    [Parameter] public string Value { get; set; }

    List<SubFiltro> filtros = new List<SubFiltro>();
    private bool exibir = false;

    private string UltimoTermoEnviado { get; set; } = "";

    [Parameter]public bool variasPalavras { get; set; }
    [Parameter]public List<SubFiltro> filtros2 { get; set; }

    [Parameter] public EventCallback<string> OnSearch { get; set; }

    private DemoContextFactory db = new DemoContextFactory();

    private ApplicationDbContext Context;

    HashSet<string> termosValidos = null;

    HashSet<string> stopWords = null;

    protected override async  Task  OnInitializedAsync()
    {
        Context = db.CreateDbContext(null);       

        stopWords = new HashSet<string>(StringComparer.OrdinalIgnoreCase) 
    { 
        "de", "do", "da", "dos", "das", "em", "no", "na", "nos", "nas", 
        "com", "por", "para", "um", "uma", "os", "as", "o", "a", "e" 
    };


    }

    private async Task OnInputChanged(KeyboardEventArgs e)
    {
        variasPalavras = true;
        exibir = true;
        if (e.Key == "Enter")
        {
            // 1. Limpeza: Remove espaços extras (ex: "Baleia     " vira "Baleia")
            var termoLimpo = Value.Trim();

            // 2. Bloqueio: Só envia se o termo atual for diferente do último enviado
            // E se não estiver vazio
            if (!string.IsNullOrWhiteSpace(termoLimpo) && termoLimpo != UltimoTermoEnviado)
            {
                UltimoTermoEnviado = termoLimpo; 
                bool apenasNumeros=false;

                    termoLimpo = termoLimpo
                    .Replace("-", "")
                    .Replace("Jarvis", "")
                    .Replace("jarvis", "")
                    .Replace("Alexa", "")
                    .Replace("alexa", "")
                    .Replace("Pesquisar", "")
                    .Replace("pesquisar", "")
                    .Replace("Limpar", "")
                    .Replace("limpar", "")
                    .Replace("Converter", "")
                    .Replace("converter", "")
                    .Trim();

                apenasNumeros = Regex.IsMatch(termoLimpo
                .Replace(" ", "")
                .Replace(",", ""),
                 @"^\d+$");
                if (apenasNumeros || termoLimpo.Contains("Marcar")
                 || termoLimpo.Contains("marcar"))              
                {
                    await OnSearch.InvokeAsync(termoLimpo); 
                }
                else
                {
                    
                    var texto = await TraduzirIntencaoComIA(termoLimpo);

                    if (texto != null)
                    {
                        // Envia o Nome do primeiro resultado (o mais relevante) encontrado pelo banco                        
                        List<SubFiltro> listaOrdenada = new List<SubFiltro>();
                        var arr = texto.Replace(" ", "")
                        .Split(',');
                        var result = "";
                        foreach(var item2 in arr)
                        {
                            var fil = filtros2.FirstOrDefault(f => 
                                f.Nome.ToLower()
                                .Contains(item2.ToLower()));
                            if( fil != null)
                                listaOrdenada.Add(fil);
                        }
                        listaOrdenada = listaOrdenada.Where(f => f.CamadaId != 1)
                        .OrderBy(f => f.CamadaId).ToList();
                        filtros.Clear();

                        foreach(var item in listaOrdenada)
                        {
                            var fil = filtros2
                            .FirstOrDefault(f => f.Nome.ToLower()
                            .Contains(item.Nome.ToLower()));
                            if(fil != null)
                            {
                                
                                bool hierarquiaValida = verificarHierarquia(fil, filtros);
                                if(!hierarquiaValida)
                                filtros.Add(fil);
                                
                            }
                        }
                            filtros = filtros.Distinct().ToList();
                            var l = filtros.Select( f => f.Nome).ToList();
                            result = string.Join(", ", l);

                        //  texto = texto.Replace(",", "");
                        await js.InvokeAsync<object>("DarAlert", "Conteudo encontrado. ");
                        await OnSearch.InvokeAsync($"{termoLimpo} - {result}"); 
                    }
                    else
                    {
                        // Se o banco não achou nada com Full-Text, você pode usar a IA aqui 
                        // apenas como um plano B (Fallback) para tentar adivinhar o que o usuário quis dizer.
                        await OnSearch.InvokeAsync(null);
                    }          

                    //  }
                }                            
            }
            else if(string.IsNullOrWhiteSpace(termoLimpo))
                await OnSearch.InvokeAsync("");
        }
        exibir = false;
    }

    // Provavelmente seu código está assim:


    private async Task OnInputChanged(ChangeEventArgs e)
    {
        variasPalavras = false;
        var value = e.Value.ToString();

        if(value.Count() >= UltimoTermoEnviado.Count() + 4 ||
        value.Count() <= UltimoTermoEnviado.Count() - 4)
        {
            filtros.Clear();
            await OnSearch.InvokeAsync(value); 
            UltimoTermoEnviado = value; 
            return;
        }

        var arr = value.Split(' ');
        if(
            arr[arr.Length - 1].Contains("pesquisar") ||
            arr[arr.Length - 1].Contains("Pesquisar") ||
            arr[arr.Length - 1].Contains("converter") ||
            arr[arr.Length - 1].Contains("Converter") ||
            arr[arr.Length - 1].Contains("limpar") ||
            arr[arr.Length - 1].Contains("Limpar") 
         )
        foreach(var item in arr)
        {
             if(
            arr[arr.Length - 1].Contains("pesquisar") ||
            arr[arr.Length - 1].Contains("Pesquisar") 
               )
            {
                await OnInputChanged(new KeyboardEventArgs { Key = "Enter" });
                    break;
            }
            else if(
            arr[arr.Length - 1].Contains("converter") ||
            arr[arr.Length - 1].Contains("Converter") 
               )
            {
               Value = converter(value);
                    break;
            }
            else if(
                    arr[arr.Length - 1].Contains("limpar") ||
                    arr[arr.Length - 1].Contains("Limpar") 
                    )
                    {
                        Value = "";
                        filtros.Clear();
                        await OnInputChanged(new KeyboardEventArgs { Key = "Enter" });
                        break;
                    }
        }
    }

    private bool verificarHierarquia(SubFiltro c, List<SubFiltro>? fils)
    {
        bool teste = false;
        var a = c;
            if(fils.Contains(c))
            teste = true;
            if(fils.Count == 0 ||
             fils.FirstOrDefault(f => f.CamadaId == c.CamadaId) != null)  
             {
                fils.Add(c);
                teste = true;
             }        
           else         
            foreach(var item in fils)  
            {
                a = item;
                while(a.CamadaId != 1)
                {
                    if(a.Id == c.Id)
                    {
                        teste = true;
                        break;
                    }  
                    a = verificarFiltros(a);
                }
            } 
        return teste;
    }

    private SubFiltro verificarFiltros(SubFiltro a)
        {
            var b = filtros2
            .FirstOrDefault(fil =>
            fil.Id == a.FiltroId)!;

            return b; 
        }

    private async Task<string> TraduzirIntencaoComIA(string textoUsuario)
    {
    if (string.IsNullOrWhiteSpace(textoUsuario)) return string.Empty;

        termosValidos = new HashSet<string>(
        filtros2.OrderBy(f => f.Nome).Select(f => f.Nome.Trim()), 
        StringComparer.OrdinalIgnoreCase );

        // Criamos uma lista com os nomes reais que você tem no banco para orientar a IA
        // Isso ajuda a evitar que ela invente nomes que não existem no seu sistema
        string termosDisponiveis = string.Join(", ", termosValidos ?? new HashSet<string>()); 

         var prompt = $@"Você é um sistema inteligente de mapeamento taxonômico e correspondência biológica.
            Sua tarefa é analisar a frase ou característica digitada pelo usuário e associá-la a um ou mais termos válidos do nosso sistema.

            Lista de Termos Válidos disponíveis (Estrito):
            [{termosDisponiveis}]

            Texto digitado pelo usuário: '{textoUsuario}'

            Regras Estritas de Resposta:
            1. Analise o texto do usuário e determine qual ou quais palavras da lista de 'Termos Válidos' possuem relação direta, sinônimo ou característica biológica com o que foi digitado.
            2. Responda APENAS com as palavras exatas encontradas na lista de 'Termos Válidos'.
            3. Se houver mais de um termo correspondente, separe-os estritamente por uma vírgula e um espaço (exemplo: TermoA, TermoB).
            4. Não invente termos novos. Se a palavra não estiver explicitamente em [{termosDisponiveis}], ignore-a.
            5. Não adicione saudações, explicações, aspas, introduções ou pontuação. Escreva apenas os termos ou a palavra NENHUM.
            6. Se o texto do usuário não tiver qualquer relação lógica ou biológica com nenhum dos termos válidos, responda estritamente: NENHUM

            Exemplos de comportamento esperado:
            Usuário: 'animais com pintas'
            Resposta: Canidae, Felidae
            Usuário: 'insetos de colmeia'
            Resposta: Abelhas
            Usuário: 'sapos e rãs'
            Resposta: Bufonidae
            Usuário: 'onde fica o meu carrinho de compras'
            Resposta: NENHUM";

            // Pegue sua chave gratuita no site ai.google.dev

            string apiKey = "";  

            // Configura o modelo (o gemini-2.5-flash é excelente e gratuito)
            var googleAI = new GoogleAI(apiKey);
            var model = googleAI.GenerativeModel(Model.Gemini25Flash);

            // Envia o prompt de forma assíncrona
            var response = await model.GenerateContent(prompt);

            // O texto da resposta estará aqui:
            Console.WriteLine(response.Text);

            try
            {
                
                    var resultadoIA = response.Text;

                    if (string.Equals(resultadoIA, "NENHUM", StringComparison.OrdinalIgnoreCase))
                    {
                        return string.Empty;
                    }

                return resultadoIA ?? string.Empty;
            }
            catch (Exception)
            {
                // Fallback: se a IA falhar por algum motivo, retorna o próprio texto limpo
                return textoUsuario;
            }
}
    
     private string converter(string textoUsuario)
     {
        // Lógica de conversão aqui
        // Exemplo: se o usuário digitar "converter Mamíferos em vers 62".
        // Depois é só pesquisar
       var apenasNumeros = Regex.IsMatch(textoUsuario
                .Replace(" ", "")
                .Replace(",", ""),
                 @"^\d+$");

        string result = "";
        if(!apenasNumeros)
        {
            if(filtros.Count > 0)
            {            
                var l = filtros.Select( f => retornarVerso(f.Criterio.Content)).ToList();
                result = string.Join(", ", l);            
            }
        }
        else
        {
            var l = filtros.Select( f => f.Nome).ToList();
                result = string.Join(", ", l);  
        }
        return result;
     }

     private int retornarVerso(business.business.conteudo.Content c)
    {
        Pagina pag = (Pagina)c;
        return pag.Versiculo;
    }
   
}